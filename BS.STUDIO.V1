-- NEUE TEAM-FUNKTIONEN
local playerDropdown = AimTab:Dropdown({
    Title = "Player List",
    Values = GetPlayerNames(),
    Value = "",
    Callback = function(v)
        selectedPlayer = v
    end
})

AimTab:Button({
    Title = "Add to Team",
    Callback = function()
        if selectedPlayer and selectedPlayer ~= "" then
            local plr = Players:FindFirstChild(selectedPlayer)
            if plr and plr ~= LocalPlayer then
                local already = false
                for _, p in pairs(CustomTeamPlayers) do
                    if p == plr then
                        already = true
                        break
                    end
                end
                if not already then
                    table.insert(CustomTeamPlayers, plr)
                                    else
                    WindUI:Notify({Title = "Team", Content = plr.Name .. " ist bereits im Team!", Duration = 2})
                end
            end
        end
    end
})

AimTab:Toggle({
    Title = "Click to Add Team",
    Value = false,
    Callback = function(v)
        ClickToAddTeam = v
    end
})

