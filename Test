-- ===== CLEANUP =====
local function CleanupESP()
    for _, box in pairs(ESPBoxes) do box:Remove() end
    for _, name in pairs(ESPNames) do name:Remove() end
    for _, health in pairs(ESPHealth) do health:Remove() end
    for _, tracer in pairs(Tracers) do tracer:Remove() end
    for _, cham in pairs(Chams) do cham:Destroy() end
    ESPBoxes = {}
    ESPNames = {}
    ESPHealth = {}
    Tracers = {}
    Chams = {}
end

