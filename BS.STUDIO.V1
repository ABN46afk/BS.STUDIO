-- Hintergrund
local function SetBackgroundImage()
    local bgImage = "https://photos.app.goo.gl/qsCDGZ6vVQVcpLEE8"
    local success, result = pcall(function()
        return game:GetService("ContentProvider"):PreloadAsync({bgImage})
    end)
    local bg = Instance.new("ImageLabel")
    bg.Name = "AzicHubBackground"
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.Position = UDim2.new(0, 0, 0, 0)
    bg.BackgroundTransparency = 1
    bg.Image = bgImage
    bg.ZIndex = 0
    local mainGui = CoreGui:FindFirstChild("WindUI")
    if mainGui then
        local frame = mainGui:FindFirstChild("MainFrame") or mainGui:FindFirstChildWhichIsA("Frame")
        if frame then
            bg.Parent = frame
        else
            bg.Parent = mainGui
        end
    end
end
task.spawn(function()
    local attempts = 0
    while not bg.Parent and attempts < 20 do
        task.wait(1)
        attempts = attempts + 1
        local gui = CoreGui:FindFirstChild("WindUI")
        if gui then
            local f = gui:FindFirstChild("MainFrame") or gui:FindFirstChildWhichIsA("Frame")
            if f then
                bg.Parent = f
            else
                bg.Parent = gui
            end
        end
    end
end)
task.spawn(SetBackgroundImage)

