local function create3DLetter(letter, startX)

	local layers = {}


	local function makeLayer(color, offset, transparency)

		local t = Instance.new("TextLabel")

		t.Size = UDim2.fromOffset(900,900)

		t.AnchorPoint = Vector2.new(.5,.5)

		t.Position = UDim2.fromScale(startX,.55)

		t.BackgroundTransparency = 1

		t.Text = letter

		t.Font = Enum.Font.Arcade

		t.TextSize = 750

		t.TextColor3 = color

		t.TextTransparency = transparency

		t.TextStrokeTransparency = 0

		t.Parent = gui

		table.insert(layers,t)

		return t
	end


	local shadow = makeLayer(
		Color3.fromRGB(0,0,0),
		12,
		0.2
	)


	local red = makeLayer(
		Color3.fromRGB(255,0,0),
		6,
		0
	)


	local main = makeLayer(
		Color3.fromRGB(255,255,255),
		0,
		0
	)


	shadow.Position =
		UDim2.new(startX,12,.55,12)

	red.Position =
		UDim2.new(startX,6,.55,6)


	return layers,main

end



