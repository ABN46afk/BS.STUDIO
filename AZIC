-- Cleanup Funktion
local function CleanupGhost()
    if ghostHighlight then
        ghostHighlight:Destroy()
        ghostHighlight = nil
    end
    for _, effect in pairs(ghostEffects) do
        if effect and effect:IsA("Instance") then
            effect:Destroy()
        end
    end
    ghostEffects = {}
    for _, conn in pairs(ghostConnections) do
        conn:Disconnect()
    end
    ghostConnections = {}
end

-- Effekt anwenden
local function ApplyGhostEffect(effectType)
    CleanupGhost()
    
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if GhostRainbowEnabled then
        local highlight = Instance.new("Highlight")
        highlight.Name = "GhostGlow"
        highlight.Parent = char
        highlight.FillTransparency = 0.7
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        
        local t = 0
        local conn = RunService.RenderStepped:Connect(function(dt)
            t = t + dt * 0.2
            local color = Color3.fromHSV(t % 1, 1, 1)
            highlight.FillColor = color
            highlight.OutlineColor = color
