local function makeSound(id, volume, pitch, looped)
	local s = Instance.new("Sound")
	s.SoundId = "rbxassetid://" .. id
	s.Volume = volume or 1
	s.PlaybackSpeed = pitch or 1
	s.Looped = looped or false
	s.Parent = SoundService
	return s
end

