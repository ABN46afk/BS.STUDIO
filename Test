-- ===== MULTI-TARGET =====
local function GetTargets()
    local Targets = {}
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and Player.Character and Player.Character:FindFirstChild(TargetPart) and Player.Character:FindFirstChild("Humanoid") and Player.Character.Humanoid.Health > 0 and IsEnemy(Player) then
            local Part = Player.Character[TargetPart]
            if IsVisible(Part) then
                local Pos, Visible = Camera:WorldToViewportPoint(Part.Position)
                if Visible then
                    local Distance = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if Distance <= FOV then
                        table.insert(Targets, {Part = Part, Distance = Distance, Player = Player})
                    end
                end
            end
        end
    end
    table.sort(Targets, function(a, b) return a.Distance < b.Distance end)
    return Targets
end

-- ===== AIM-FUNKTION =====
local function AimAtTargets(Targets)
    if #Targets == 0 then return end
    local avgPos = Vector3.new(0, 0, 0)
    local count = math.min(#Targets, MaxTargets)
    local validTargets = 0
    for i = 1, count do
        if Targets[i] and Targets[i].Part then
            avgPos = avgPos + Targets[i].Part.Position
            validTargets = validTargets + 1
        end
    end
    if validTargets == 0 then return end
    avgPos = avgPos / validTargets

    if PredictionEnabled then
        local vel = Vector3.new(0, 0, 0)
        local velCount = 0
        for i = 1, count do
            local root = Targets[i].Part.Parent and Targets[i].Part.Parent:FindFirstChild("HumanoidRootPart")
            if root then
                vel = vel + root.Velocity
                velCount = velCount + 1
            end
        end
        if velCount > 0 then
            avgPos = avgPos + (vel / velCount) * PredictionAmount
        end
    end

    local currentCF = Camera.CFrame
    local targetCF = CFrame.new(currentCF.Position, avgPos)
    if AimSpeed > 0 then
        local relative = currentCF:ToObjectSpace(targetCF)
        local angles = Vector3.new(
            math.atan2(-relative.LookVector.Y, relative.LookVector.Z),
            math.atan2(relative.LookVector.X, relative.LookVector.Z),
            0
        )
        local maxAngle = math.rad(AimSpeed * 0.1)
        local clampedAngles = Vector3.new(
            math.clamp(angles.X, -maxAngle, maxAngle),
            math.clamp(angles.Y, -maxAngle, maxAngle),
            0
        )
        Camera.CFrame = currentCF * CFrame.fromEulerAnglesXYZ(clampedAngles.X, clampedAngles.Y, 0)
    else
        Camera.CFrame = targetCF
    end
end

-- ===== WEITERE FUNKTIONEN =====
local lastShot = 0
local function TriggerBot()
    if not TriggerBotEnabled then return end
    local targets = GetTargets()
    if #targets > 0 and tick() - lastShot > TriggerBotDelay then
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.001)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        lastShot = tick()
    end
end

local function AimAssist()
    if not AimAssistEnabled then return end
    local targets = GetTargets()
    if #targets > 0 then
        local target = targets[1]
        local targetPos = target.Part.Position
        if PredictionEnabled then
            local humanoidRoot = target.Part.Parent and target.Part.Parent:FindFirstChild("HumanoidRootPart")
            if humanoidRoot then
                targetPos = targetPos + (humanoidRoot.Velocity * PredictionAmount)
            end
        end
        local aimVector = (targetPos - Camera.CFrame.Position).Unit
        local newCFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + aimVector * 10), AimAssistStrength)
        Camera.CFrame = newCFrame
    end
end

local function NoRecoil()
