-- SHOCKWAVE (DOPPELTER RING)

local function makeShockwave(delay, thickness, size, color)
	task.spawn(function()
		task.wait(delay)

		local ring = Instance.new("Frame")
		ring.AnchorPoint = Vector2.new(.5,.5)
		ring.Position = UDim2.fromScale(.5,.55)
		ring.Size = UDim2.fromOffset(20,20)
		ring.BackgroundTransparency = 1
		ring.Parent = gui

		local circle = Instance.new("UICorner")
		circle.CornerRadius = UDim.new(1,0)
		circle.Parent = ring

		local stroke = Instance.new("UIStroke")
		stroke.Color = color
		stroke.Thickness = thickness
		stroke.Parent = ring

		TweenService:Create(ring, TweenInfo.new(.6, Enum.EasingStyle.Quad), {
			Size = UDim2.fromOffset(size,size),
			Transparency = 1
		}):Play()

		TweenService:Create(stroke, TweenInfo.new(.6), {Transparency = 1}):Play()
	end)
end

