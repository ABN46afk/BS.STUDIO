    Text = "Select Theme",
    Items = {"Dark","Light","Rose","Plant","Indigo","Sky","Violet","Amber","Cyber Red Blue"},
    Default = "Cyber Red Blue",
    Callback = function(value)
        if value == "Cyber Red Blue" then
            if Window.SetTheme then Window:SetTheme(CyberRedBlueTheme) end
        else
            if Window.SetTheme then Window:SetTheme(value) end
        end
        Window:Notify({ Title = "Theme System", Description = "Theme changed to " .. value, Duration = 3 })
    end
})
local UISettingsSection = SettingsTab:CreateSection({ Title = "UI Settings" })
UISettingsSection:AddButton({
    Text = "Reset UI Position",
    Callback = function()
        if Window.ResetPosition then Window:ResetPosition() end
    end
})

-- ============================================
-- FINALE NOTIFICATION
-- ============================================
Window:Notify({
    Title = "Welcome",
    Description = "Cyber Knife UI with Silent Aim & ESP loaded!",
    Duration = 4,
})

