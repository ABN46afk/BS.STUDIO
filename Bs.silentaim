-- ============================================
-- KNIFE SCRIPT (bestehend)
-- ============================================
local function setupKnifeScript()
    local Players = game:GetService("Players")
    local Workspace = game:GetService("Workspace")
    local LocalPlayer = Players.LocalPlayer
    local Camera = Workspace.CurrentCamera
    local KnifeController = require(LocalPlayer.PlayerScripts:WaitForChild("Controllers"):WaitForChild("Combat"):WaitForChild("KnifeController"))

    local function getClosestPlayer()
        local closest = nil
        local bestFOV = getgenv().KnifeConfig.FOV
        local viewportCenter = Camera.ViewportSize / 2

        for _, player in Players:GetPlayers() do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                local targetPart = player.Character:FindFirstChild(getgenv().KnifeConfig.HitPart)
                if targetPart then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                        if distance < bestFOV then
                            closest = player
                            bestFOV = distance
                        end
                    end
                end
            end
        end
        return closest
    end

    local originalGetThrowDirection = KnifeController._GetThrowDirection
    KnifeController._GetThrowDirection = function(self, character)
        if getgenv().KnifeConfig.Enabled then
            local target = getClosestPlayer()
            if target and target.Character then
                local targetPart = target.Character:FindFirstChild(getgenv().KnifeConfig.HitPart)
                if targetPart then
                    return (targetPart.Position - character.Position).Unit
                end
            end
        end
        return originalGetThrowDirection(self, character)
    end
end

pcall(setupKnifeScript)

-- ============================================
-- SILENT AIM LOGIK (für Schusswaffen)
-- ============================================
local function setupSilentAim()
    local Players = game:GetService("Players")
    local Workspace = game:GetService("Workspace")
    local LocalPlayer = Players.LocalPlayer
    local Camera = Workspace.CurrentCamera
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")

    -- FOV Circle Drawing
    local fovCircle = nil
    local function updateFOVCircle()
        if fovCircle then fovCircle:Remove() fovCircle = nil end
        if not getgenv().SilentAimConfig.Enabled or not getgenv().SilentAimConfig.ShowFOVCircle then return end
        fovCircle = Drawing.new("Circle")
        fovCircle.Thickness = 1
        fovCircle.Color = Color3.fromRGB(0, 170, 255)
        fovCircle.Filled = false
        fovCircle.NumSides = 64
        fovCircle.Radius = getgenv().SilentAimConfig.FOV
        fovCircle.Visible = true
        fovCircle.Position = Camera.ViewportSize / 2
    end

    -- Aktualisiere FOV Circle bei Änderungen
    local function onConfigChanged()
        updateFOVCircle()
    end

    -- Hook für Mausklick (Silent Aim)
    local function onInputBegan(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not getgenv().SilentAimConfig.Enabled then return end
            -- Suche nächsten Spieler im FOV
            local closestPlayer = nil
            local bestDist = getgenv().SilentAimConfig.FOV
            local viewportCenter = Camera.ViewportSize / 2
            for _, player in Players:GetPlayers() do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                    local targetPart = player.Character:FindFirstChild(getgenv().SilentAimConfig.HitPart)
                    if targetPart then
                        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                        if onScreen then
                            local dist = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                            if dist < bestDist then
                                closestPlayer = player
                                bestDist = dist
                            end
                        end
                    end
                end
            end
            if closestPlayer then
                local targetPart = closestPlayer.Character:FindFirstChild(getgenv().SilentAimConfig.HitPart)
                if targetPart then
                    -- Ändere die Blickrichtung kurzzeitig, um den Schuss zu treffen
                    local originalCF = Camera.CFrame
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
                    -- Nach einem Frame zurücksetzen (damit der Schuss registriert wird)
                    task.wait(0.01)
                    Camera.CFrame = originalCF
                end
            end
        end
    end

    -- Verbinde Events
    UserInputService.InputBegan:Connect(onInputBegan)
    -- Bei Fenstergrößenänderung FOV Circle anpassen
    RunService.RenderStepped:Connect(function()
        if fovCircle then
            fovCircle.Position = Camera.ViewportSize / 2
        end
    end)

    -- Initiale Erstellung
    updateFOVCircle()
    -- Speichere Funktion zum Aktualisieren
    getgenv().UpdateSilentAimUI = onConfigChanged
end

pcall(setupSilentAim)

-- ============================================
-- ESP LOGIK (Boxen, Nametags, Chams)
-- ============================================
local function setupESP()
    local Players = game:GetService("Players")
    local Workspace = game:GetService("Workspace")
    local LocalPlayer = Players.LocalPlayer
    local Camera = Workspace.CurrentCamera
    local RunService = game:GetService("RunService")

    local espObjects = {}
    local highlightObjects = {}

    -- Funktion zum Erstellen der ESP-Anzeigen für einen Spieler
    local function createESPForPlayer(player)
        if espObjects[player] then return end
        local obj = {}
        -- Box
        local box = Drawing.new("Square")
        box.Thickness = 1
        box.Color = Color3.fromRGB(0, 170, 255)
        box.Filled = false
        box.Visible = false
        -- Name
        local nameText = Drawing.new("Text")
        nameText.Color = Color3.new(1,1,1)
        nameText.Size = 14
        nameText.Center = true
        nameText.Visible = false
        obj.Box = box
        obj.Name = nameText
        espObjects[player] = obj

        -- Chams (Highlight)
        if getgenv().ESPConfig.Chams then
            local highlight = Instance.new("Highlight")
            highlight.FillColor = getgenv().ESPConfig.ChamsColor
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = Color3.new(1,1,1)
            highlight.OutlineTransparency = 0.3
            highlight.Parent = player.Character or player
            highlightObjects[player] = highlight
        end
    end

    -- Funktion zum Entfernen von ESP für einen Spieler
    local function removeESPForPlayer(player)
        local obj = espObjects[player]
        if obj then
            obj.Box:Remove()
            obj.Name:Remove()
            espObjects[player] = nil
        end
        local highlight = highlightObjects[player]
        if highlight then
            highlight:Destroy()
            highlightObjects[player] = nil
        end
    end

    -- Aktualisiere alle ESP-Objekte
    local function updateESP()
        if not getgenv().ESPConfig.Enabled then
            -- Alle ausblenden
            for _, obj in pairs(espObjects) do
                obj.Box.Visible = false
                obj.Name.Visible = false
            end
            return
        end

        for _, player in Players:GetPlayers() do
            if player == LocalPlayer then continue end
            if player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                -- Sicherstellen, dass ESP-Objekte existieren
                if not espObjects[player] then
                    createESPForPlayer(player)
                end
                local obj = espObjects[player]
                local character = player.Character
                local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
                if root then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local size = character:GetExtentsSize()
                        local height = size.Y
                        local width = size.X
                        local top = screenPos.Y - height / 2
                        local left = screenPos.X - width / 2
                        -- Box
                        if getgenv().ESPConfig.Boxes then
                            obj.Box.Visible = true
                            obj.Box.Position = Vector2.new(left, top)
                            obj.Box.Size = Vector2.new(width, height)
                        else
                            obj.Box.Visible = false
                        end
                        -- Name
                        if getgenv().ESPConfig.NameTags then
                            obj.Name.Visible = true
                            obj.Name.Text = player.Name
                            obj.Name.Position = Vector2.new(screenPos.X, top - 15)
                        else
                            obj.Name.Visible = false
                        end
                    else
                        obj.Box.Visible = false
                        obj.Name.Visible = false
                    end
                end
            else
                -- Spieler tot oder kein Charakter -> ESP ausblenden
                if espObjects[player] then
                    espObjects[player].Box.Visible = false
                    espObjects[player].Name.Visible = false
                end
            end
        end
    end

    -- Aktualisiere Chams (wenn aktiviert)
    local function updateChams()
        for _, player in Players:GetPlayers() do
            if player == LocalPlayer then continue end
            if getgenv().ESPConfig.Chams then
                if not highlightObjects[player] then
                    if player.Character then
                        local highlight = Instance.new("Highlight")
                        highlight.FillColor = getgenv().ESPConfig.ChamsColor
                        highlight.FillTransparency = 0.5
                        highlight.OutlineColor = Color3.new(1,1,1)
                        highlight.OutlineTransparency = 0.3
                        highlight.Parent = player.Character
                        highlightObjects[player] = highlight
                    end
                else
                    highlightObjects[player].FillColor = getgenv().ESPConfig.ChamsColor
                end
            else
                if highlightObjects[player] then
                    highlightObjects[player]:Destroy()
                    highlightObjects[player] = nil
                end
            end
        end
    end

    -- Event: Spieler treten bei / verlassen
    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(character)
            task.wait(0.5) -- warte auf Modell
            if getgenv().ESPConfig.Enabled and getgenv().ESPConfig.Chams then
                local highlight = Instance.new("Highlight")
                highlight.FillColor = getgenv().ESPConfig.ChamsColor
                highlight.FillTransparency = 0.5
                highlight.OutlineColor = Color3.new(1,1,1)
                highlight.OutlineTransparency = 0.3
                highlight.Parent = character
                highlightObjects[player] = highlight
            end
        end)
    end)

    Players.PlayerRemoving:Connect(function(player)
        removeESPForPlayer(player)
    end)

    -- Render-Schleife
    RunService.RenderStepped:Connect(updateESP)

    -- Funktion zum Neuladen der ESP-Konfiguration (wird von UI aufgerufen)
    getgenv().ReloadESP = function()
        updateChams()
        -- Alle ESP-Objekte neu erstellen (falls nötig)
        for _, player in Players:GetPlayers() do
            if player ~= LocalPlayer then
                if espObjects[player] then
                    removeESPForPlayer(player)
                end
                if getgenv().ESPConfig.Enabled then
                    createESPForPlayer(player)
                end
            end
        end
    end
end

pcall(setupESP)

-- ============================================
-- FUNKTIONEN FÜR SKY UND BACKGROUND (Fortsetzung)
-- ============================================
local function setBackground(visible, transparency, imageId)
    if not backgroundImage then
        local mainFrame = Window.Frame or Window.Main or (Window:GetMainFrame and Window:GetMainFrame())
        if mainFrame then
            backgroundImage = Instance.new("ImageLabel")
            backgroundImage.Name = "BackgroundImage"
            backgroundImage.Size = UDim2.new(1, 0, 1, 0)
            backgroundImage.Position = UDim2.new(0, 0, 0, 0)
            backgroundImage.BackgroundTransparency = 1
            backgroundImage.Image = imageId or "rbxassetid://134891041950620"
            backgroundImage.ZIndex = 0
            backgroundImage.Parent = mainFrame
        else
            warn("Could not find main frame for background image")
            return
        end
    end

    if backgroundImage then
        backgroundImage.Visible = visible
        backgroundImage.ImageTransparency = 1 - transparency
        if imageId then
            backgroundImage.Image = imageId
        end
    end
end

