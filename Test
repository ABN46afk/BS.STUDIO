local function ServerHop()
    if not ServerHopEnabled then return end
    local servers = {}
    for _, v in pairs(game:GetService("HttpService"):JSONDecode(game:GetService("HttpService"):GetAsync("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100")).data) do
