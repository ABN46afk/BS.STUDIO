		0.5,
		0.25
	)


	logo.BackgroundTransparency = 1


	logo.Image =
		"rbxassetid://134891041950620"


	logo.ImageColor3 = color


	logo.ImageTransparency = transparency


	logo.Parent = gui



	table.insert(
		logoLayers,
		logo
	)


	return logo

end



